# API keys used by the pipeline. The recommended way to set these is to export
# them from your shell profile (see README, "API keys"); this file is only an
# optional fallback loaded via python-dotenv. Copy it to `.env` and fill in your
# keys. NEVER commit the filled-in `.env`.

# Gemini (Stage 1 failure reasoning) -- https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# GEMINI_API_KEY=      # accepted as an alias for GOOGLE_API_KEY

# OpenAI (Stages 2-3, runtime monitoring, LLM-judge) -- https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Anthropic (alternative LLM-judge)
# ANTHROPIC_API_KEY=

# Optional: Together AI (Llama / DeepSeek clustering baselines)
# TOGETHER_API_KEY=
